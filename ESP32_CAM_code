#include "esp_camera.h"
#include "Arduino.h"

#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27
#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5
#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22

HardwareSerial SerialWROOM(1);
#define WROOM_TX_PIN  14
#define WROOM_RX_PIN  15
#define UART_BAUD     921600

// END_MARKER 4 bytes bao hieu het data binary
// Chon ky tu khong bao gio xuat hien trong JPEG: 0x00 0x00 0x00 0x00
// JPEG chi co 0x00 0x00 ben trong entropy data, khong bao gio 4 zero lien tiep o level frame
static const uint8_t END_MARKER[4] = {0xDE, 0xAD, 0xBE, 0xEF};
#define ACK_TIMEOUT  15000   // ms cho ACK tu WROOM

void initCamera() {
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer   = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM; config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM; config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM; config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM; config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk     = XCLK_GPIO_NUM;
  config.pin_pclk     = PCLK_GPIO_NUM;
  config.pin_vsync    = VSYNC_GPIO_NUM;
  config.pin_href     = HREF_GPIO_NUM;
  config.pin_sscb_sda = SIOD_GPIO_NUM;
  config.pin_sscb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn     = PWDN_GPIO_NUM;
  config.pin_reset    = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;
  config.frame_size   = FRAMESIZE_XGA;  // 1024x768
  config.jpeg_quality = 10;             // 10 = chat luong kha (thang nguoc)
  config.fb_count     = 1;

  esp_err_t err = esp_camera_init(&config);
  if (err != ESP_OK) {
    Serial.printf("[CAM] Init that bai: 0x%x\n", err);
    while (1) delay(1000);
  }
  Serial.println("[CAM] Camera OK");
}

// Cho 1 trong cac token mong doi tu WROOM
// Tra ve token nhan duoc ("OK", "READY") hoac "" neu timeout
String waitToken(unsigned long timeout_ms) {
  String line = "";
  unsigned long start = millis();
  while (millis() - start < timeout_ms) {
    while (SerialWROOM.available()) {
      char c = SerialWROOM.read();
      if (c == '\n') {
        line.trim();
        if (line == "OK" || line == "READY") return line;
        line = "";
      } else {
        line += c;
      }
    }
    delay(5);
  }
  return "";
}

void sendImage() {
  camera_fb_t *fb = esp_camera_fb_get();
  if (!fb) {
    Serial.println("[CAM] Chup anh that bai!");
    delay(1000);
    return;
  }

  size_t imgSize = fb->len;
  Serial.printf("[CAM] Chup anh: %u bytes\n", imgSize);

  while (SerialWROOM.available()) SerialWROOM.read();

  // Gui header
  SerialWROOM.printf("START:%u\n", imgSize);
  SerialWROOM.flush();
  delay(20);

  // Gui binary theo block 1KB
  size_t sent = 0;
  unsigned long t0 = millis();
  while (sent < imgSize) {
    size_t blk = min((size_t)1024, imgSize - sent);
    sent += SerialWROOM.write(fb->buf + sent, blk);
    SerialWROOM.flush();
  }

  // Gui END_MARKER
  SerialWROOM.write(END_MARKER, 4);
  SerialWROOM.flush();
  Serial.printf("[CAM] Da gui %u bytes trong %lums, cho ACK...\n", sent, millis() - t0);

  esp_camera_fb_return(fb);

  // ---- Buoc 1: cho ACK "OK" (WROOM nhan du anh) ----
  String tok = waitToken(ACK_TIMEOUT);
  if (tok != "OK") {
    Serial.println("[CAM] Timeout ACK, thu lai sau 3s...");
    delay(3000);
    return;
  }
  Serial.println("[CAM] Nhan OK, cho WROOM xu ly YOLO...");

  // ---- Buoc 2: cho "READY" (WROOM xu ly YOLO xong, san sang nhan anh moi) ----
  // [FIX] Khong delay co dinh nua - doi tin hieu thuc te tu WROOM
  //       Timeout 15s: du cho HTTP + YOLO inference + margin
  tok = waitToken(15000);
  if (tok == "READY") {
    Serial.println("[CAM] Nhan READY, gui anh tiep!");
  } else {
    Serial.println("[CAM] Timeout READY, gui anh tiep sau 2s...");
    delay(2000);
  }
}

void setup() {
  Serial.begin(115200);
  SerialWROOM.begin(UART_BAUD, SERIAL_8N1, WROOM_RX_PIN, WROOM_TX_PIN);
  delay(500);
  initCamera();
  Serial.println("[CAM] San sang, cho WROOM...");
  delay(3000);  // cho WROOM khoi dong xong
}

void loop() {
  sendImage();
}
